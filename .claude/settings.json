{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(git status)",
      "Bash(git status:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh",
            "statusMessage": "Provisioning CIDOC-CRM POC substrates (Postgres/AGE/Neo4j/rdflib)..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scope-check.sh",
            "timeout": 10,
            "statusMessage": "Checking scope accountability..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-merge-check.sh",
            "timeout": 10,
            "statusMessage": "Checking pre-merge PR hygiene..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-curl-github.sh",
            "timeout": 10,
            "statusMessage": "Checking for curl-to-GitHub bypass..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-revise-priors.sh",
            "timeout": 10,
            "statusMessage": "Checking for unresolved revise-priors markers..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-pr-create.sh",
            "timeout": 30,
            "statusMessage": "Checking PR workflow..."
          }
        ]
      }
    ]
  }
}
