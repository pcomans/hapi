{
  "enabledPlugins": {
    "code-review@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/scope-check.sh",
            "timeout": 10,
            "statusMessage": "Checking scope accountability..."
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-merge-check.sh",
            "timeout": 10,
            "statusMessage": "Checking pre-merge PR hygiene..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/post-pr-create.sh",
            "timeout": 30,
            "statusMessage": "Checking PR workflow..."
          }
        ]
      }
    ]
  }
}
